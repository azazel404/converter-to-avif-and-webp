PORT=3001
HOST=0.0.0.0

# Max size for single-file upload (bytes): 50 MB default
MAX_SINGLE_FILE_SIZE=52428800

# Max size for zip upload (bytes): 500 MB default
MAX_ZIP_SIZE=524288000

# Max files per zip
MAX_FILES_PER_ZIP=500

# Default quality (0-100) for lossy formats
DEFAULT_QUALITY=82

# SSIM threshold for auto-format selection (0-1)
QUALITY_THRESHOLD=0.95

# Worker concurrency for batch jobs
WORKER_CONCURRENCY=4

# Temp directory for job files
TEMP_DIR=/tmp/converter-jobs

# Job TTL in milliseconds (1 hour)
JOB_TTL_MS=3600000

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
